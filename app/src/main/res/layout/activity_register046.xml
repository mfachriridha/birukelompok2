<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="32dp"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:gravity="center">
    <TextView android:text="Daftar Akun" android:textSize="28sp" android:textStyle="bold"
        android:textColor="@color/biru_primary" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:layout_marginBottom="32dp"/>
    <EditText android:id="@+id/et_name" android:hint="Nama Lengkap"
        android:inputType="textPersonName" android:padding="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/et_nim" android:hint="NIM"
        android:inputType="number" android:padding="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/et_email" android:hint="Email"
        android:inputType="textEmailAddress" android:padding="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"/>
    <EditText android:id="@+id/et_password" android:hint="Password"
        android:inputType="textPassword" android:padding="12dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>
    <Button android:id="@+id/btn_register" android:text="Daftar"
        android:layout_width="match_parent" android:layout_height="56dp"
        android:backgroundTint="@color/biru_primary" android:textColor="@color/white"/>
</LinearLayout>
